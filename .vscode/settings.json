{
  "latex-workshop.latex.tools": [
    {
      "name": "latexmk",
      "command": "/usr/local/texlive/2025/bin/universal-darwin/latexmk",
      "args": [
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "-pdf",
        "-f",
        "-g",
        "-outdir=%OUTDIR%",
        "%DOC%"
      ],
      "env": {
        "PATH": "/usr/local/texlive/2025/bin/universal-darwin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
      }
    },
    {
      "name": "latexmk_clean",
      "command": "/usr/local/texlive/2025/bin/universal-darwin/latexmk",
      "args": ["-C", "%DOC%"],
      "env": {
        "PATH": "/usr/local/texlive/2025/bin/universal-darwin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
      }
    },
    {
      "name": "pdflatex",
      "command": "/usr/local/texlive/2025/bin/universal-darwin/pdflatex",
      "args": [
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "%DOC%"
      ],
      "env": {
        "PATH": "/usr/local/texlive/2025/bin/universal-darwin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
      }
    },
    {
      "name": "bibtex",
      "command": "/usr/local/texlive/2025/bin/universal-darwin/bibtex",
      "args": ["%DOCFILE%"],
      "env": {
        "PATH": "/usr/local/texlive/2025/bin/universal-darwin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
      }
    }
  ],
  "latex-workshop.latex.recipes": [
    {
      "name": "Clean and Build (latexmk)",
      "tools": ["latexmk_clean", "latexmk"]
    },
    {
      "name": "latexmk",
      "tools": ["latexmk"]
    },
    {
      "name": "pdflatex -> bibtex -> pdflatex*2",
      "tools": ["pdflatex", "bibtex", "pdflatex", "pdflatex"]
    }
  ],
  "latex-workshop.latex.outDir": "%DIR%",
  "latex-workshop.latex.autoBuild.run": "onSave",
  "latex-workshop.latex.autoClean.run": "onFailed",
  "latex-workshop.view.pdf.viewer": "tab"
}
