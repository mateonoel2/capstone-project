# Anthropic API Configuration (for Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# LlamaParse API Configuration
LLAMA_CLOUD_API_KEY=your_llama_cloud_api_key_here

# Database (optional — defaults to SQLite for local dev)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/extractions

# Railway Buckets / S3 storage (optional — defaults to local disk)
# BUCKET_ENDPOINT=https://your-bucket-endpoint.railway.app
# BUCKET_ACCESS_KEY_ID=your_access_key
# BUCKET_SECRET_ACCESS_KEY=your_secret_key
# BUCKET_NAME=uploads
# BUCKET_REGION=auto
