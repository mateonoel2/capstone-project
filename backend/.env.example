# Anthropic API Configuration (for Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# LlamaParse API Configuration
LLAMA_CLOUD_API_KEY=your_llama_cloud_api_key_here

# Database (local Docker Postgres — defaults to SQLite without this)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/extractions

# S3 storage (LocalStack via docker-compose — defaults to local disk without this)
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_S3_BUCKET_NAME=uploads
AWS_DEFAULT_REGION=us-east-1
